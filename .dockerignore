# Node modules
node_modules/
**/node_modules/
npm-debug.log
yarn-error.log
yarn.lock
package-lock.json

# Environment variables (should be provided at runtime)
.env
.env.local
.env.*.local
**/.env

# Database files (persisted via volumes)
*.db
*.db-journal
*.sqlite
*.sqlite3
data/

# Logs (persisted via volumes)
logs/
*.log

# Test and coverage
coverage/
.nyc_output/
test-results/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Git
.git/
.gitignore
.gitattributes

# Documentation (not needed in container)
docs/
*.md
!README.md

# Docker files (not needed inside container)
Dockerfile
docker-compose.yml
.dockerignore

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Frontend build artifacts (built during Docker build)
frontend/dist/
frontend/node_modules/

# Backend artifacts
backend/node_modules/
backend/data/
backend/logs/

# Temporary files
tmp/
temp/
*.tmp

# Claude/Superpowers directories
.claude/
.superpowers/
