# ========================================
# Family Football Betting App
# Environment Configuration
# ========================================

# -----------------------------------------
# Server Configuration
# -----------------------------------------

# Port number the server will listen on
# Default: 3000
PORT=3000

# Node environment (development or production)
# In production, frontend static files are served from /public
# In development, use separate frontend dev server
# Default: development
NODE_ENV=development

# -----------------------------------------
# Security & Authentication
# -----------------------------------------

# JWT Secret Key - REQUIRED
# This is used to sign and verify JWT tokens
# IMPORTANT: Generate a strong, random secret key for production
# Minimum 32 characters recommended
#
# Generate a secure key using:
#   openssl rand -base64 32
#   OR
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# WARNING: Never commit your actual secret key to version control!
JWT_SECRET=your-secret-key-min-256-bits-CHANGE-THIS-IN-PRODUCTION

# JWT Token Expiration Time
# How long authentication tokens remain valid
# Examples: 7d (7 days), 24h (24 hours), 30m (30 minutes)
# Default: 7d
JWT_EXPIRES_IN=7d

# -----------------------------------------
# Database Configuration
# -----------------------------------------

# Path to SQLite database file
# For Docker: /app/data/betting.db (persisted via volume)
# For local development: ./data/betting.db
# Default: ./data/betting.db
DATABASE_PATH=./data/betting.db

# -----------------------------------------
# External API Keys (Optional)
# -----------------------------------------

# API-Football API Key
# Get your key at: https://www.api-football.com/
# Used for:
#   - Fetching live match data
#   - Updating match scores in real-time
#   - Getting match schedules
#
# Note: App works without this key, but won't have live data
# You'll need to manually create matches via admin panel
API_FOOTBALL_KEY=your-api-football-key

# The Odds API Key
# Get your key at: https://the-odds-api.com/
# Used for:
#   - Fetching real-time betting odds
#   - Updating odds for matches
#
# Note: App works without this key, but odds won't update automatically
# You'll need to manually set odds via admin panel
ODDS_API_KEY=your-odds-api-key

# -----------------------------------------
# Application Settings (Optional)
# -----------------------------------------

# Daily Coin Grant Amount
# How many coins each user receives daily (via cron job)
# Default: 10
# DAILY_COINS=10

# Minimum Bet Amount
# Minimum coins required to place a bet
# Default: 1
# MIN_BET_AMOUNT=1

# Initial User Coins
# Coins granted to new users on registration
# Default: 0 (users get coins from daily grants)
# INITIAL_USER_COINS=0

# -----------------------------------------
# Cron Job Schedule (Optional)
# -----------------------------------------
# These use standard cron syntax: https://crontab.guru/

# Daily Coin Grant Schedule
# When to grant daily coins to all users
# Default: 0 0 * * * (midnight every day)
# CRON_DAILY_COINS=0 0 * * *

# Match Odds Update Schedule
# How often to update betting odds from external API
# Default: */30 * * * * (every 30 minutes)
# CRON_ODDS_UPDATE=*/30 * * * *

# Live Score Update Schedule
# How often to check for live match score updates
# Default: */2 * * * * (every 2 minutes)
# CRON_SCORE_UPDATE=*/2 * * * *

# -----------------------------------------
# Logging Configuration (Optional)
# -----------------------------------------

# Log Level
# Options: error, warn, info, debug
# Default: info
# LOG_LEVEL=info

# Log to File
# Set to true to write logs to file
# Default: false
# LOG_TO_FILE=false

# Log File Path
# Where to write log files
# Default: ./logs/app.log
# LOG_FILE_PATH=./logs/app.log

# -----------------------------------------
# Notes
# -----------------------------------------

# 1. Copy this file to .env and fill in your values
# 2. Never commit your .env file to version control
# 3. For Docker deployment, set these in docker-compose.yml or .env file
# 4. For production, always generate a new JWT_SECRET
# 5. External API keys are optional - app works without them

