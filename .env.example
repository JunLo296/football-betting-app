# ========================================
# Family Football Betting App
# Docker Deployment Configuration
# ========================================

# This file is used for Docker Compose deployment
# Copy this file to .env and fill in your actual values

# -----------------------------------------
# REQUIRED: Security Configuration
# -----------------------------------------

# JWT Secret Key - REQUIRED for production
# Generate a secure key using:
#   openssl rand -base64 32
#   OR
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# WARNING: Never use the default value in production!
JWT_SECRET=CHANGE-THIS-TO-A-SECURE-RANDOM-KEY-IN-PRODUCTION

# -----------------------------------------
# OPTIONAL: External API Keys
# -----------------------------------------

# API-Football API Key (Optional)
# Get your key at: https://www.api-football.com/
# Leave empty if you don't have an API key
# API_FOOTBALL_KEY=

# The Odds API Key (Optional)
# Get your key at: https://the-odds-api.com/
# Leave empty if you don't have an API key
# ODDS_API_KEY=

# -----------------------------------------
# OPTIONAL: Advanced Configuration
# -----------------------------------------

# JWT Token Expiration Time
# Default: 7d (7 days)
JWT_EXPIRES_IN=7d

# -----------------------------------------
# Notes for Docker Deployment
# -----------------------------------------
# 1. Copy this file to .env in the project root
# 2. Generate a strong JWT_SECRET (see above)
# 3. Fill in API keys if you have them (optional)
# 4. Run: docker-compose up -d
# 5. Create admin user: docker-compose exec football-betting-app npm run seed
# 6. Access the app at: http://localhost:3000
